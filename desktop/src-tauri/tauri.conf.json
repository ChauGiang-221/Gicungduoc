{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gicungduoc",
  "version": "1.0.0",
  "identifier": "com.gicungduoc.app",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist",
    "devtools": true
  },
  "app": {
    "windows": [
      {
        "title": "Gicungduoc AI",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
