{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["hnd1"],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://${RAILWAY_PUBLIC_DOMAIN}/api/:path*"
    }
  ]
}
